# ============================================================
# Databricks connection
# ============================================================
DATABRICKS_HOST=your-databricks-host
DATABRICKS_URL=your-databricks-url
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_TOKEN=dapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABRICKS_CATALOG_NAME=commerce_agent_catalog
DATABRICKS_SCHEMA_NAME=gold

# ============================================================
# BGE Reranker
# ============================================================
# Options: cpu | cuda | mps
RERANKER_DEVICE=cpu
BGE_CHECKPOINT_PATH=models/bge-reranker

# ============================================================
# BPR checkpoint
# ============================================================
BPR_CHECKPOINT_PATH=models/bpr/model.npz
